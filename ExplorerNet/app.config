<?xml version="1.0"?>
<configuration>
    <configSections>
        <sectionGroup name="userSettings" type="System.Configuration.UserSettingsGroup, System.Configuration.ConfigurationManager">
            <section name="ExplorerNet.Properties.Settings" type="System.Configuration.ClientSettingsSection, System.Configuration.ConfigurationManager" allowExeDefinition="MachineToLocalUser" requirePermission="false"/>
        </sectionGroup>
        <sectionGroup name="applicationSettings" type="System.Configuration.ApplicationSettingsGroup, System.Configuration.ConfigurationManager">
            <section name="ExplorerNet.Properties.Settings" type="System.Configuration.ClientSettingsSection, System.Configuration.ConfigurationManager" requirePermission="false"/>
        </sectionGroup>
    </configSections>
    <userSettings>
        <ExplorerNet.Properties.Settings>
            <setting name="HeightLevel" serializeAs="String">
                <value>300</value>
            </setting>
            <setting name="WidthFilepanel" serializeAs="String">
                <value>250</value>
            </setting>
            <setting name="FileOverwriteOption" serializeAs="String">
                <value>ShowDialog</value>
            </setting>
            <setting name="FilepanelIcoWidth" serializeAs="String">
                <value>35</value>
            </setting>
            <setting name="FilepanelNameWidth" serializeAs="String">
                <value>200</value>
            </setting>
            <setting name="FilepanelSizeWidth" serializeAs="String">
                <value>80</value>
            </setting>
            <setting name="ViewWindowTop" serializeAs="String">
                <value>NaN</value>
            </setting>
            <setting name="ViewWindowLeft" serializeAs="String">
                <value>NaN</value>
            </setting>
            <setting name="ViewWindowHeight" serializeAs="String">
                <value>500</value>
            </setting>
            <setting name="ViewWindowWidth" serializeAs="String">
                <value>800</value>
            </setting>
            <setting name="ViewWindowState" serializeAs="String">
                <value>Normal</value>
            </setting>
            <setting name="CurrentSkin" serializeAs="String">
                <value>rainierpurple</value>
            </setting>
            <setting name="CurrentCulture" serializeAs="String">
                <value>(Default)</value>
            </setting>
            <setting name="CurrLang" serializeAs="String">
                <value/>
            </setting>
            <setting name="LanguageSelectorVisible" serializeAs="String">
                <value>True</value>
            </setting>
            <setting name="LastNameAssemblie" serializeAs="String">
                <value/>
            </setting>
            <setting name="FilepanelStarWidth" serializeAs="String">
                <value>30</value>
            </setting>
        </ExplorerNet.Properties.Settings>
    </userSettings>
    <applicationSettings>
        <ExplorerNet.Properties.Settings>
            <setting name="FileAppExtention" serializeAs="String">
                <value>.enet</value>
            </setting>
        </ExplorerNet.Properties.Settings>
    </applicationSettings>
</configuration>
