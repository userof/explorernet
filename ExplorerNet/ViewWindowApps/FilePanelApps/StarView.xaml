<UserControl x:Class="ExplorerNet.ViewWindowApps.FilePanelApps.StarView"
             x:Name="star"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"

             mc:Ignorable="d"
             xmlns:local="clr-namespace:ExplorerNet.ViewWindowApps.FilePanelApps"
             MouseDoubleClick="star_MouseDoubleClick"
             d:DesignHeight="300" d:DesignWidth="300">
    <UserControl.Resources>
        <ResourceDictionary />
    </UserControl.Resources>
    <UserControl.Style>
        <Style>
            <Style.Triggers>
                <Trigger Property="local:StarView.StarLevel" Value="{x:Null}">
                    <Setter Property="Polygon.Opacity" Value="0.1" />
                </Trigger>
                <Trigger Property="local:StarView.StarLevel" Value="One">
                    <Setter Property="Polygon.Opacity" Value="0.4" />
                </Trigger>
                <Trigger Property="local:StarView.StarLevel" Value="Two">
                    <Setter Property="Polygon.Opacity" Value="0.7" />
                </Trigger>
                <Trigger Property="local:StarView.StarLevel" Value="Three">
                    <Setter Property="Polygon.Opacity" Value="1" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Style>
    <Grid>
        <!-- 5-point star polygon replacing ed:RegularPolygon -->
        <Polygon Name="rpStar"
                 PreviewMouseLeftButtonDown="RegularPolygon_PreviewMouseLeftButtonDown"
                 Cursor="Hand" StrokeThickness="2" Opacity="1"
                 Fill="Orange" Stroke="Black"
                 Points="145,0 185,105 290,115 210,185 235,290 145,230 55,290 80,185 0,115 105,105"
                 Stretch="Uniform" Width="290" Height="290">
            <Polygon.Triggers>
                <EventTrigger RoutedEvent="MouseDown" SourceName="rpStar">
                    <EventTrigger.Actions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation
                                    Storyboard.TargetName="rpStar"
                                    Storyboard.TargetProperty="(RenderTransform).(RotateTransform.Angle)"
                                    From="0"
                                    To="360"
                                    Duration="0:0:0.5"
                                    RepeatBehavior="1x" />
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger.Actions>
                </EventTrigger>
            </Polygon.Triggers>
            <Polygon.RenderTransform>
                <RotateTransform Angle="0"
                         CenterX="95"
                         CenterY="20" />
            </Polygon.RenderTransform>
        </Polygon>
    </Grid>
</UserControl>
